# Backend production environment template. Do not put real secrets here.

APP_NAME=DocuMind AI
ENVIRONMENT=production

DATABASE_URL=
REDIS_URL=

SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documind_chunks

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small
EMBEDDING_VECTOR_SIZE=384

RERANKER_PROVIDER=local
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_CANDIDATE_LIMIT=50
RERANKER_TOP_K=5

LLM_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions

ANSWER_MIN_SCORE=0.55

RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=5
RATE_LIMIT_AUTH_REGISTER_PER_MINUTE=3
RATE_LIMIT_RAG_PER_MINUTE=30
RATE_LIMIT_KEYWORD_SEARCH_PER_MINUTE=60
RATE_LIMIT_RERANK_PER_MINUTE=20
RATE_LIMIT_EVAL_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=5
RATE_LIMIT_DOCUMENT_PROCESSING_PER_MINUTE=10
RATE_LIMIT_READ_PER_MINUTE=120
RATE_LIMIT_CHUNKS_READ_PER_MINUTE=60
